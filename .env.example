# Auth credentials for Claude Agent SDK.
# Copy to .env and fill in your values.
# The agent runs in a clean environment (like env -i) —
# only vars listed here and minimal system vars are passed through.

# Bedrock auth (preferred)
# AWS_BEARER_TOKEN_BEDROCK=ABSK...
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1

# Or standard AWS assumed-role credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Or direct Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...
